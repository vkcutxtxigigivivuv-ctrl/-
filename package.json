{
  "name": "shot-study-tool",
  "productName": "ShotStudyTool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "start": "concurrently -k \"npm:dev\" \"wait-on tcp:5173 && npm:electron:dev\"",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "build": "vite build && tsc -p electron/tsconfig.json && copy /Y electron\\preload.cjs dist-electron\\preload.cjs",
    "dist": "npm.cmd run build && electron-builder --win --x64",
    "dist:dir": "npm.cmd run build && electron-builder --win --x64 --dir --config.directories.output=release-adaptive-cinema-ui",
    "preview": "vite preview --host 127.0.0.1"
  },
  "build": {
    "appId": "com.local.shotstudytool",
    "productName": "ShotStudyTool",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.0.0",
    "lucide-react": "^0.468.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.0",
    "typescript": "^5.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.0"
  }
}
